{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["driftguard"],
  "title": "DriftGuard Service Health",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active model tier (baseline=1 means DEGRADED)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK" }, "1": { "text": "DEGRADED" } } }
          ],
          "thresholds": { "steps": [
            { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "targets": [
        { "expr": "driftguard_model_tier{tier=\"baseline\"}", "legendFormat": "baseline",
          "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "requests", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency (s)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error rate (5xx req/s)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count{status=~\"5.*\"}[5m]))",
          "legendFormat": "5xx", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Predictions by tier (req/s)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(driftguard_predictions_total[1m])) by (served_by)",
          "legendFormat": "{{served_by}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Fallback rate (req/s)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(driftguard_fallback_total[1m])", "legendFormat": "fallback",
          "refId": "A" }
      ]
    }
  ]
}
