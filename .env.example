# Copy to .env for local overrides. NEVER commit a real .env.
# Secrets in production come from AWS Secrets Manager / the CI credential store.

# DRIFTGUARD_LOG_LEVEL=INFO
# DRIFTGUARD_RANDOM_SEED=42

# MLflow tracking + registry (sqlite by default for a self-contained local run)
# DRIFTGUARD_MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# DRIFTGUARD_PRIMARY_MODEL_URI=models:/driftguard/Production

# Promotion gate: candidate macro-F1 must beat baseline by >= this margin
# DRIFTGUARD_PROMOTION_MARGIN=0.0

# Drift detection
# DRIFTGUARD_PSI_THRESHOLD=0.2

# Speed knob for demos: subsample the training split (0 = full dataset)
# DRIFTGUARD_MAX_TRAIN_ROWS=0
